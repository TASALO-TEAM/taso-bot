# Telegram Bot Token (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# IDs de administradores (separados por coma)
ADMIN_CHAT_IDS=123456789,987654321

# Backend API URL
TASALO_API_URL=http://localhost:8000

# API Key para endpoints admin (mismo valor que ADMIN_API_KEY en taso-api)
TASALO_ADMIN_KEY=your_admin_key_here

# Timeouts (segundos)
API_TIMEOUT_SECONDS=15

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
