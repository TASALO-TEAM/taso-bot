# =============================================================================
# TASALO-BOT — Variables de Entorno
# =============================================================================
# Copia este archivo a .env y configura los valores para tu entorno.
# 
# cp .env.example .env
#
# Todos los valores son requeridos a menos que se indique lo contrario.
# =============================================================================


# =============================================================================
# TELEGRAM — Configuración del Bot
# =============================================================================

# Token del bot obtenido de @BotFather en Telegram.
# 
# Cómo obtenerlo:
#   1. Abre Telegram y busca @BotFather
#   2. Envía /newbot y sigue las instrucciones
#   3. Copia el token que te devuelve (tiene formato: 1234567890:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw)
#
# ⚠️ NUNCA compartas este token. Mantén tu .env seguro.
TELEGRAM_BOT_TOKEN=your_bot_token_here


# =============================================================================
# ADMINISTRADORES — Control de Acceso
# =============================================================================

# IDs de chat de administradores separados por coma.
#
# Los administradores pueden usar comandos privilegiados:
#   - /refresh: Fuerza refresco inmediato de tasas en el backend
#   - /status: Muestra estado del scheduler del backend
#   - /health: Verifica conexión con el backend
#
# Cómo obtener tu user_id:
#   1. Busca @userinfobot en Telegram
#   2. Inicia el bot y te mostrará tu ID numérico
#   3. Copia ese número aquí
#
# Formato: "123456789" o "123456789,987654321" para múltiples admins
# Ejemplo: ADMIN_CHAT_IDS=123456789,987654321
ADMIN_CHAT_IDS=


# =============================================================================
# BACKEND API — Conexión con taso-api
# =============================================================================

# URL base de la API de taso-api.
#
# Desarrollo local:
#   TASALO_API_URL=http://localhost:8040
#
# Producción (con dominio):
#   TASALO_API_URL=https://api.tasalo.app
#
# Producción (con IP):
#   TASALO_API_URL=http://192.168.1.100:8040
#
# ⚠️ El bot debe poder alcanzar esta URL desde donde se ejecute.
TASALO_API_URL=http://localhost:8040


# API key para endpoints administrativos del backend.
#
# Este valor debe ser IDÉNTICO al ADMIN_API_KEY configurado en taso-api.
# 
# Cómo configurarlo:
#   1. En taso-api, edita .env y establece ADMIN_API_KEY=tu_clave_secreta
#   2. Aquí, establece TASALO_ADMIN_KEY=tu_clave_secreta (mismo valor)
#
# ⚠️ Usa una clave segura (mínimo 32 caracteres, mezcla de letras, números).
#   Genera una con: openssl rand -hex 32
#
# Si no se configura, los comandos /refresh y /status no funcionarán.
TASALO_ADMIN_KEY=


# =============================================================================
# TIMEOUTS — Configuración de Red
# =============================================================================

# Timeout para llamadas HTTP a la API en segundos.
#
# Rango válido: 5-60 segundos
# Valor recomendado: 15 (equilibrio entre paciencia y UX)
#
# Si la API no responde en este tiempo, el bot muestra error al usuario.
# Aumentar solo si tu backend es consistentemente lento.
API_TIMEOUT_SECONDS=15


# =============================================================================
# LOGGING — Depuración y Monitoreo
# =============================================================================

# Nivel de logging para la salida estándar (stdout).
#
# Niveles disponibles:
#   - DEBUG:   Mensajes detallados para desarrollo (muy verboso)
#   - INFO:    Mensajes informativos (producción estándar)
#   - WARNING: Solo advertencias y errores
#   - ERROR:   Solo errores críticos
#
# Recomendado:
#   - Desarrollo: DEBUG
#   - Producción: INFO
LOG_LEVEL=INFO


# =============================================================================
# EJEMPLOS DE CONFIGURACIÓN
# =============================================================================
#
# ─────────────────────────────────────────────────────────────────────────────
# DESARROLLO LOCAL
# ─────────────────────────────────────────────────────────────────────────────
#
# TELEGRAM_BOT_TOKEN=1234567890:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw
# ADMIN_CHAT_IDS=123456789
# TASALO_API_URL=http://localhost:8040
# TASALO_ADMIN_KEY=dev_key_no_segura_para_produccion
# API_TIMEOUT_SECONDS=15
# LOG_LEVEL=DEBUG
#
# ─────────────────────────────────────────────────────────────────────────────
# PRODUCCIÓN (systemd en VPS)
# ─────────────────────────────────────────────────────────────────────────────
#
# TELEGRAM_BOT_TOKEN=1234567890:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw
# ADMIN_CHAT_IDS=123456789,987654321
# TASALO_API_URL=http://127.0.0.1:8040
# TASALO_ADMIN_KEY=genera_con_openssl_rand_hex_32_muy_segura
# API_TIMEOUT_SECONDS=15
# LOG_LEVEL=INFO
#
# ─────────────────────────────────────────────────────────────────────────────
# PRODUCCIÓN (Docker con taso-api en misma red)
# ─────────────────────────────────────────────────────────────────────────────
#
# TELEGRAM_BOT_TOKEN=1234567890:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw
# ADMIN_CHAT_IDS=123456789
# TASALO_API_URL=http://taso-api:8040
# TASALO_ADMIN_KEY=${TASALO_ADMIN_KEY_FROM_SECRETS}
# API_TIMEOUT_SECONDS=15
# LOG_LEVEL=INFO
#
# =============================================================================
